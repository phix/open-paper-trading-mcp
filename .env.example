# =====================================================================
# Open Paper Trading MCP — example environment file
# =====================================================================
# Bootstrap your local config with:
#
#     cp .env.example .env
#
# Then edit only the values you need. The hub runs out-of-the-box with
# the defaults below: QUOTE_ADAPTER_TYPE=test serves synthetic data with
# NO API keys required. Add secrets only when you opt into a real-data or
# cloud-LLM provider.
#
# PAPER-ONLY: no real money is ever traded. Real credentials below are
# used for READ-ONLY market data, never for live order routing.
#
# Secrets live in `.env`, which is gitignored — NEVER commit real keys.
# Leave placeholders untouched for anything you are not using.
# =====================================================================

# ---------------------------------------------------------------------
# Core application settings  (all optional — sane defaults shown)
# ---------------------------------------------------------------------
ENVIRONMENT="development"            # development | production
DEBUG=True                          # verbose errors + reload in dev
PROJECT_NAME="Open Paper Trading MCP"
API_V1_STR="/api/v1"                # REST API path prefix
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# ---------------------------------------------------------------------
# Server / ports  (optional)
# ---------------------------------------------------------------------
# FastAPI REST API + frontend listen on 2080; the MCP tool server on 2081.
FASTAPI_PORT=2080                   # REST API + React frontend (http://localhost:2080)
MCP_SERVER_PORT=2081                # MCP tool server
MCP_SERVER_HOST=localhost           # use 0.0.0.0 in Docker
MCP_HTTP_PORT=2081                  # MCP HTTP transport port
MCP_HTTP_URL=http://localhost:2081  # MCP endpoint (used by ADK evals)

# ---------------------------------------------------------------------
# CORS  (optional)
# ---------------------------------------------------------------------
# Comma-separated list of origins allowed to call the API.
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:2080"

# ---------------------------------------------------------------------
# Database  (REQUIRED)
# ---------------------------------------------------------------------
# Async PostgreSQL DSN — must use the postgresql+asyncpg:// scheme.
# In Docker the host is `db`; for a local Postgres use `localhost`.
DATABASE_URL="postgresql+asyncpg://trading_user:trading_password@localhost:5432/trading_db"

# Redis (optional; reserved for future caching/queues)
REDIS_URL="redis://localhost:6379"

# ---------------------------------------------------------------------
# Security  (optional in dev — CHANGE for any shared/prod deployment)
# ---------------------------------------------------------------------
SECRET_KEY="your-secret-key-change-this-in-production"

# ---------------------------------------------------------------------
# Quote adapter — selects the market-data source  (optional; default: test)
# ---------------------------------------------------------------------
# QUOTE_ADAPTER_TYPE values:
#   test       -> synthetic data, ZERO keys required (default, recommended start)
#   robinhood  -> live READ-ONLY Robinhood market data (needs ROBINHOOD_* below)
#   openbb     -> OpenBB Platform data (ADR 0002); zero-key default provider is
#                 yfinance — add OpenBB provider keys below only for FMP/Polygon/etc.
QUOTE_ADAPTER_TYPE=test

# Synthetic-data tuning — only used when QUOTE_ADAPTER_TYPE=test
TEST_SCENARIO=ui_testing
TEST_DATE=2025-07-30

# ---------------------------------------------------------------------
# Robinhood credentials  (OPTIONAL — only when QUOTE_ADAPTER_TYPE=robinhood)
# ---------------------------------------------------------------------
# READ-ONLY market data only. Leave blank for the keyless `test` adapter.
ROBINHOOD_USERNAME=""               # your Robinhood email
ROBINHOOD_PASSWORD=""               # your Robinhood password
ROBINHOOD_TOKEN_PATH="/app/.tokens" # where the auth token is cached

# ---------------------------------------------------------------------
# OpenBB provider keys  (OPTIONAL — only when QUOTE_ADAPTER_TYPE=openbb; ADR 0002)
# ---------------------------------------------------------------------
# The openbb adapter falls back to the free `yfinance` provider with NO key.
# Add keys only to use a premium provider; they are passed to OpenBB at
# startup (obb.user.credentials) and never committed. Examples:
# OPENBB_FMP_API_KEY=""             # Financial Modeling Prep
# OPENBB_POLYGON_API_KEY=""         # Polygon.io
# OPENBB_INTRINIO_API_KEY=""        # Intrinio

# ---------------------------------------------------------------------
# LLM / agent provider  (OPTIONAL — provider seam per ADR 0004)
# ---------------------------------------------------------------------
# The agent layer selects an inference provider behind a seam. These vars
# are the proposed contract (not yet wired in hub code — see ADR 0004).
# Uncomment and set when the local-LLM repoint lands.
#
# LLM_PROVIDER=local                            # local | gemini
# LLM_BASE_URL=http://tinman.tailc095b7.ts.net:1234/v1   # LM Studio endpoint (Tailscale MagicDNS, not bare "tinman")
# LLM_API_KEY=lm-studio                         # non-secret placeholder; LM Studio ignores it
# LLM_MODEL=qwen2.5-coder-7b-instruct           # local model served by LM Studio
#
# Gemini path (used when LLM_PROVIDER=gemini, and by the ADK example/evals):
# GOOGLE_GENAI_USE_VERTEXAI=0
# GOOGLE_API_KEY=""                             # your Google API key (SECRET — keep blank if unused)
# GOOGLE_MODEL=gemini-1.5-flash-preview-0514
